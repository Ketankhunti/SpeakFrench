# Azure Speech Services
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=canadacentral

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Stripe (CAD)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Redis (distributed session locks — disable for single-instance dev)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
SESSION_LOCK_TTL_SECONDS=1800
SESSION_LOCK_HEARTBEAT_SECONDS=15

# Admin (email that can access /admin metrics panel)
ADMIN_EMAIL=
